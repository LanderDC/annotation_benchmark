@article{buchfinkSensitiveProteinAlignments2021,
  title = {Sensitive Protein Alignments at Tree-of-Life Scale Using {{DIAMOND}}},
  author = {Buchfink, Benjamin and Reuter, Klaus and Drost, Hajk-Georg},
