@article{terzianPHROGFamiliesProkaryotic2021,
  title = {{{PHROG}}: Families of Prokaryotic Virus Proteins Clustered Using Remote Homology},
  shorttitle = {{{PHROG}}},
  author = {Terzian, Paul and Olo~Ndela, Eric and Galiez, Clovis and Lossouarn, Julien and P{\'e}rez~Bucio, Rub{\'e}n~Enrique and Mom, Robin and Toussaint, Ariane and Petit, Marie-Agn{\`e}s and Enault, Fran{\c c}ois},
  year = 2021,
  month = sep,
  journal = {NAR Genomics and Bioinformatics},
  volume = {3},
  number = {3},
  pages = {lqab067},
  issn = {2631-9268},
  doi = {10.1093/nargab/lqab067},
  urldate = {2026-01-28},
  abstract = {Viruses are abundant, diverse and ancestral biological entities. Their diversity is high, both in terms of the number of different protein families encountered and in the sequence heterogeneity of each protein family. The recent increase in sequenced viral genomes constitutes a great opportunity to gain new insights into this diversity and consequently urges the development of annotation resources to help functional and comparative analysis. Here, we introduce PHROG (Prokaryotic Virus Remote Homologous Groups), a library of viral protein families generated using a new clustering approach based on remote homology detection by HMM profile-profile comparisons. Considering 17~473 reference (pro)viruses of prokaryotes, 868~340 of the total 938~864 proteins were grouped into 38~880 clusters that proved to be a 2-fold deeper clustering than using a classical strategy based on BLAST-like similarity searches, and yet to remain homogeneous. Manual inspection of similarities to various reference sequence databases led to the annotation of 5108 clusters (containing 50.6~\% of the total protein dataset) with 705 different annotation terms, included in 9 functional categories, specifically designed for viruses. Hopefully, PHROG will be a useful tool to better annotate future prokaryotic viral sequences thus helping the scientific community to better understand the evolution and ecology of these entities.}
}

@article{altschulBasicLocalAlignment1990,
  title = {Basic Local Alignment Search Tool},
  author = {Altschul, Stephen F. and Gish, Warren and Miller, Webb and Myers, Eugene W. and Lipman, David J.},
  year = 1990,
  volume = {215},
  number = {3},
  pages = {403--410},
  publisher = {J Mol Biol},
  doi = {10.1016/S0022-2836(05)80360-2},
  urldate = {2021-02-22},
  abstract = {A new approach to rapid sequence comparison, basic local alignment search tool (BLAST), directly approximates alignments that optimize a measure of local similarity, the maximal segment pair (MSP) score. Recent mathematical results on the stochastic properties of MSP scores allow an analysis of the performance of this method as well as the statistical significance of alignments it generates. The basic algorithm is simple and robust; it can be implemented in a number of ways and applied in a variety of contexts including straight-forward DNA and protein sequence database searches, motif searches, gene identification searches, and in the analysis of multiple regions of similarity in long DNA sequences. In addition to its flexibility and tractability to mathematical analysis, BLAST is an order of magnitude faster than existing sequence comparison tools of comparable sensitivity. \copyright{} 1990, Academic Press Limited. All rights reserved.},
  pmid = {2231712},
  keywords = {Algorithms,Amino Acid Sequence,Base Sequence*,D J Lipman,Databases,doi:10.1016/S0022-2836(05)80360-2,Factual,MEDLINE,Mutation*,National Center for Biotechnology Information,National Institutes of Health,National Library of Medicine,NCBI,NIH,NLM,Nucleic Acid,P.H.S.,pmid:2231712,PubMed Abstract,Research Support,S F Altschul,Sensitivity and Specificity,Sequence Homology,Software*,U.S. Gov't,W Gish}
}

